{
  "manifest_version": 3,
  "name": "Netflix Ratings Overlay",
  "version": "1.0.0",
  "description": "Injects IMDb, Rotten Tomatoes, and Metacritic ratings into Netflix title modals.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.netflix.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["src/content/contentScript.ts"],
      "css": ["src/content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/serviceWorker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Netflix Ratings Overlay"
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
